# ============================================================================
# TRADING SYSTEM - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=trading-system
APP_VERSION=0.2.0
ENVIRONMENT=development  # development, staging, production
DEBUG=true
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# DATABASE CONFIGURATION (TimescaleDB/PostgreSQL)
# ============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_db
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# Database URL (constructed from above or override)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Redis Cache
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6379
REDIS_CACHE_DB=0
REDIS_CACHE_PASSWORD=

# Redis Streams (for market data)
REDIS_STREAMS_HOST=localhost
REDIS_STREAMS_PORT=6380
REDIS_STREAMS_DB=0
REDIS_STREAMS_PASSWORD=

# Redis URLs
REDIS_CACHE_URL=redis://${REDIS_CACHE_HOST}:${REDIS_CACHE_PORT}/${REDIS_CACHE_DB}
REDIS_STREAMS_URL=redis://${REDIS_STREAMS_HOST}:${REDIS_STREAMS_PORT}/${REDIS_STREAMS_DB}

# ============================================================================
# EXCHANGE API CREDENTIALS
# ============================================================================

# Binance
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true  # Use testnet for development
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# Bybit
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_TESTNET=true

# OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# Kraken
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ============================================================================
# TRADING CONFIGURATION
# ============================================================================
# Trading Mode: paper, live
TRADING_MODE=paper

# Initial Capital (USDT)
INITIAL_CAPITAL=10000.0

# Risk Management
MAX_POSITION_SIZE_PCT=10.0  # Max % of capital per position
MAX_TOTAL_EXPOSURE_PCT=50.0  # Max % of capital in all positions
MAX_DAILY_LOSS_PCT=5.0  # Max daily loss before circuit breaker
MAX_LEVERAGE=3.0

# Order Execution
ORDER_TIMEOUT_SECONDS=30
MAX_RETRIES=3
SLIPPAGE_TOLERANCE_PCT=0.5

# ============================================================================
# STRATEGY CONFIGURATION
# ============================================================================
# Active Strategies (comma-separated)
ACTIVE_STRATEGIES=rsi_macd,bollinger_bands

# Strategy Parameters (example for RSI+MACD)
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# ============================================================================
# MARKET DATA CONFIGURATION
# ============================================================================
# Symbols to trade (comma-separated)
TRADING_SYMBOLS=BTC/USDT,ETH/USDT,BNB/USDT

# Default timeframe
DEFAULT_TIMEFRAME=15m

# Data retention (days)
DATA_RETENTION_DAYS=730  # 2 years

# WebSocket reconnect settings
WS_RECONNECT_DELAY=5
WS_MAX_RECONNECT_ATTEMPTS=10

# ============================================================================
# BACKTESTING CONFIGURATION
# ============================================================================
BACKTEST_START_DATE=2023-01-01
BACKTEST_END_DATE=2024-01-01
BACKTEST_INITIAL_CAPITAL=10000.0
BACKTEST_COMMISSION=0.001  # 0.1%
BACKTEST_SLIPPAGE=0.0005  # 0.05%

# ============================================================================
# API SERVER CONFIGURATION
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true  # Hot reload for development

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true

# API Authentication
API_SECRET_KEY=change_this_to_a_random_secret_key_in_production
API_ALGORITHM=HS256
API_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# MONITORING & ALERTING
# ============================================================================
# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=true

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me

# Alerting Channels
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=
EMAIL_TO=
EMAIL_PASSWORD=

# Alert Thresholds
ALERT_ON_DAILY_LOSS_PCT=3.0
ALERT_ON_POSITION_SIZE_PCT=15.0
ALERT_ON_API_ERROR=true

# ============================================================================
# PERFORMANCE & OPTIMIZATION
# ============================================================================
# C++ Execution Engine
USE_CPP_EXECUTION=false  # Enable when C++ module compiled
CPP_THREAD_POOL_SIZE=4

# Caching
CACHE_TTL_SECONDS=30
CACHE_ENABLED=true

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_SECOND=10

# ============================================================================
# SECURITY
# ============================================================================
# Encryption key for sensitive data
ENCRYPTION_KEY=generate_a_32_byte_key_here

# IP Whitelist (comma-separated, empty = allow all)
IP_WHITELIST=

# Enable 2FA for API
REQUIRE_2FA=false

# ============================================================================
# DEVELOPMENT & TESTING
# ============================================================================
# Testing
TEST_DATABASE_URL=postgresql+asyncpg://test_user:test_pass@localhost:5433/test_trading_db
RUN_INTEGRATION_TESTS=false
RUN_E2E_TESTS=false

# Profiling
ENABLE_PROFILING=false
PROFILE_OUTPUT_DIR=./profiling_results

# ============================================================================
# DOCKER CONFIGURATION
# ============================================================================
COMPOSE_PROJECT_NAME=trading-system
DOCKER_BUILDKIT=1
